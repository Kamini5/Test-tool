{
  "entities": {
    "GeneratedDocument": {
      "title": "Generated Document",
      "description": "A document generated by the AI assistant.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["SRS", "FRS", "TestPlan", "TestCases", "Environment", "Automation"] },
        "projectName": { "type": "string" },
        "description": { "type": "string" },
        "referenceUrl": { "type": "string" },
        "additionalDetails": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "projectName", "content", "createdAt"]
    }
  },
  "firestore": {
    "/documents/{documentId}": {
      "schema": "GeneratedDocument",
      "description": "Collection of all generated documents."
    }
  }
}
