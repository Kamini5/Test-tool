rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidDocument(data) {
      return data.userId == request.auth.uid &&
             data.type in ['SRS', 'FRS', 'TestPlan', 'TestCases', 'Environment', 'Automation'] &&
             data.projectName is string && data.projectName.size() <= 200 &&
             data.content is string && data.content.size() <= 100000 &&
             data.createdAt == request.time;
    }

    match /documents/{docId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                      isValidId(docId) && 
                      isValidDocument(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
